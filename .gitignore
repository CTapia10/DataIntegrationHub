## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ins.

# Archivos específicos del usuario
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Resultados de compilación (¡Los más importantes!)
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Directorio de caché y opciones de Visual Studio (2015/2017/2019/2022)
.vs/

# Herramientas de cobertura de código y pruebas
TestResults/
*.coverage
*.coveragexml

# Archivos de caché de Entity Framework Core
*.efcore/

# Entornos de desarrollo adicionales (VS Code, Rider, Mac)
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.DS_Store
.venv

# Archivos temporales de Docker
.dockerignore
docker-compose.override.yml